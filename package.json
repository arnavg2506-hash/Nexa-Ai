{
  "name": "nexa-ai-property-intelligence",
  "version": "1.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "build:next": "next build",
    "build:sites": "npm run build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "start:next": "next start",
    "start:sites": "npm run start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm run build:next && npm run build",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.mjs"
  },
  "dependencies": {
    "@prisma/client": "^7.9.0",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.26.0",
    "mapbox-gl": "^3.27.0",
    "next": "^16.2.11",
    "openai": "^6.49.0",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "recharts": "^3.10.0",
    "resend": "^6.18.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.45.1",
    "@next/swc-wasm-nodejs": "^15.5.18",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.5.10",
    "prisma": "^6.19.0",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vinext": "0.0.50",
    "vite": "8.1.5",
    "wrangler": "4.112.0"
  },
  "overrides": {
    "postcss": "$postcss"
  },
  "type": "module"
}
