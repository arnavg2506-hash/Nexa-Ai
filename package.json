{
  "name": "nexa-ai-property-intelligence",
  "version": "1.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "build:next": "next build",
    "build:sites": "npm run build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "start:next": "next start",
    "start:sites": "npm run start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm run build:next && npm run build",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "framer-motion": "^12.0.0",
    "lucide-react": "^0.468.0",
    "mapbox-gl": "^3.24.0",
    "next": "^15.0.0",
    "openai": "^6.39.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1",
    "resend": "^6.17.2"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.47.0",
    "@next/swc-wasm-nodejs": "^16.2.11",
    "@types/node": "^26.1.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "6.0.4",
    "@vitejs/plugin-rsc": "0.5.30",
    "autoprefixer": "^10.5.4",
    "eslint": "^10.7.0",
    "eslint-config-next": "^16.2.11",
    "postcss": "^8.5.22",
    "prisma": "^7.9.0",
    "react-server-dom-webpack": "19.2.8",
    "tailwindcss": "^4.3.3",
    "typescript": "^7.0.2",
    "vinext": "0.2.1",
    "vite": "8.1.5",
    "wrangler": "4.114.0"
  },
  "overrides": {
    "postcss": "$postcss"
  },
  "type": "module"
}
